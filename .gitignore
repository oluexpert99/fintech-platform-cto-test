# =============================================================================
#  Maven / JVM build output
# =============================================================================
**/target/
*.class
*.jar
*.war
*.ear
*.original
hs_err_pid*.log
replay_pid*.log
dependency-reduced-pom.xml
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar


# =============================================================================
#  Test reports / Testcontainers / JaCoCo
# =============================================================================
**/surefire-reports/
**/failsafe-reports/
**/jacoco.exec
**/jacoco-it.exec
**/site/jacoco/


# =============================================================================
#  IDE files
# =============================================================================
.idea/
*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/
.factorypath
.springBeans
.sts4-cache/
nb-configuration.xml
nb-actions.xml


# =============================================================================
#  OS files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*~
*.swp
*.swo


# =============================================================================
#  Secrets / local config — NEVER commit
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets.yaml
secrets.yml
*.local.yaml
*.local.yml


# =============================================================================
#  Logs / runtime
# =============================================================================
*.log
logs/
spring.log
spring-shell.log


# =============================================================================
#  Docker / Compose runtime state
# =============================================================================
# Keep docker-compose.yml + Dockerfiles + infra/ committed.
# But ignore anything generated by a running compose stack.
docker-compose.override.yml
.docker/
*.pid


# =============================================================================
#  Node tooling
# =============================================================================
# `node_modules/` is universally ignored (the platform-ui's own .gitignore also lists it).
# `package-lock.json` is intentionally COMMITTED — reproducible installs matter for the
# frontend build. Only the npx-cache and parcel-cache are noisy.
node_modules/
.cache/
.parcel-cache/


# =============================================================================
#  Generated documentation
# =============================================================================
# The .docx brief stays; the PDF is a deliverable — keep both committed.
# Intermediate HTML from md-to-pdf attempts is NOT a deliverable.
docs/*.html


# =============================================================================
#  Claude Code project state — local only, never share
# =============================================================================
.claude/


# =============================================================================
#  Misc
# =============================================================================
*.tmp
*.bak
*.orig
*.rej
